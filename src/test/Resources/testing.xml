<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Amazon Search Test Suite" parallel="false" verbose="2">

    <listeners>
        <listener class-name="com.amazon.utils.TestListener"/>
    </listeners>

    <test name="Positive Search Tests">
        <classes>
            <class name="com.amazon.tests.PositiveSearchTest"/>
        </classes>
    </test>

</suite>